{
  "buildCommand": "pnpm build",
  "outputDirectory": "out",
  "framework": null,
  "installCommand": "pnpm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/ota-manifest.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
